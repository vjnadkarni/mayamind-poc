<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Transport Security -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>companion.mayamind.ai</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <false/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- Camera Usage -->
    <key>NSCameraUsageDescription</key>
    <string>MayaMind uses the camera to track your exercise movements and provide real-time coaching feedback.</string>

    <!-- Microphone Usage -->
    <key>NSMicrophoneUsageDescription</key>
    <string>MayaMind uses the microphone for voice conversations with Maya and to send voice messages.</string>

    <!-- Speech Recognition -->
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>MayaMind uses speech recognition to understand your voice commands and have natural conversations.</string>

    <!-- HealthKit -->
    <key>NSHealthShareUsageDescription</key>
    <string>MayaMind reads your health data from Apple Watch to display vitals and track your wellness progress.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>MayaMind may save exercise data to HealthKit to help track your fitness progress.</string>

    <!-- Photo Library -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>MayaMind accesses your photos to send pictures to family and friends via WhatsApp.</string>

    <!-- Supported Interface Orientations -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- iPad Specific -->
    <key>UIRequiresFullScreen</key>
    <true/>

    <!-- Background Modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>remote-notification</string>
    </array>

    <!-- iCloud -->
    <key>com.apple.developer.icloud-container-identifiers</key>
    <array>
        <string>iCloud.ai.mayamind.app</string>
    </array>

    <!-- Launch Storyboard -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <!-- Scene Configuration -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>
</dict>
</plist>
