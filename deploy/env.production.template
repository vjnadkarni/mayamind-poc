# MayaMind Production Environment Variables
# Copy this to /var/www/mayamind/.env and fill in your values

# Server
PORT=3001
NODE_ENV=production

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Deepgram (Speech-to-Text for POC - not used in dashboard)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Twilio (WhatsApp messaging)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Public URL for Twilio webhooks (update this!)
NGROK_URL=https://companion.mayamind.ai

# Withings (body composition - optional)
WITHINGS_CLIENT_ID=your_withings_client_id_here
WITHINGS_CLIENT_SECRET=your_withings_client_secret_here

# Supabase (cloud sync - optional)
# SUPABASE_URL=your_supabase_url_here
# SUPABASE_ANON_KEY=your_supabase_anon_key_here
